# Generated by scripts/init-sonar.sh after first docker compose up
SONAR_TOKEN=

# Redis connection string
REDIS_URL=redis://redis:6379

# API port
PORT=3000

# Number of concurrent analysis jobs (lower to avoid resource contention with ops tools)
WORKER_CONCURRENCY=1

# SonarQube admin password (change from default 'admin' on first run)
SONAR_ADMIN_PASSWORD=

# PostgreSQL password for analysis history storage
POSTGRES_PASSWORD=changeme

# Git clone depth (50 recommended for git hygiene analysis)
GIT_CLONE_DEPTH=50

# Opt-out of specific ops scanners (set to "true" to skip)
SKIP_TRIVY=false
SKIP_GITLEAKS=false
SKIP_HADOLINT=false
SKIP_CHECKOV=false

# Custom risk mappings path (optional, defaults to built-in config)
# RISK_MAPPINGS_PATH=/path/to/custom-risk-mappings.json
